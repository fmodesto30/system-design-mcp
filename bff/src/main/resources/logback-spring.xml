<?xml version="1.0" encoding="UTF-8"?>
<!-- Structured-ish console logging with a requestId from the MDC (set by RequestIdFilter).
     Keeps key fields explicit so logs are greppable without pulling a JSON encoder dependency. -->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} level=%-5level reqId=%X{requestId:-} logger=%logger{36} msg="%replace(%msg){'\"','\\"'}"%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
